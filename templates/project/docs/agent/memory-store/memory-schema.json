{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Context OS Retrieval Memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "status",
    "type",
    "scope",
    "summary",
    "content",
    "source",
    "confidence",
    "last_verified"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^mem-[0-9]{8}-[0-9]{3}$"
    },
    "status": {
      "type": "string",
      "enum": ["current", "draft", "assumption", "deprecated", "stale"]
    },
    "type": {
      "type": "string",
      "enum": [
        "project_fact",
        "business_rule",
        "interaction_rule",
        "architecture_rule",
        "implementation_note",
        "known_issue",
        "decision",
        "open_question"
      ]
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref", "date"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user_confirmed",
            "code",
            "test",
            "doc",
            "decision",
            "task_report",
            "issue",
            "conversation_summary"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "last_verified": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "replaces": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replaced_by": {
      "type": "string"
    }
  }
}
